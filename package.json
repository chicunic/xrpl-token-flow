{
  "name": "xrpl-token-flow",
  "version": "1.0.0",
  "description": "XRPL token flow management service",
  "scripts": {
    "check": "tsc -p tests/tsconfig.json --noEmit && biome check --enforce-assist=true",
    "fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:local": "vitest run --config vitest.config.local.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "postinstall": "chmod +x setup-hooks.sh && ./setup-hooks.sh"
  },
  "keywords": [
    "xrp",
    "xrpl",
    "trust-line",
    "mptoken",
    "flow",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.7"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
