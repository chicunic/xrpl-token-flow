{
  "name": "xrpl-token-flow",
  "version": "1.0.0",
  "description": "XRPL token flow management service",
  "scripts": {
    "check": "tsc -b --noEmit && eslint . && prettier --check .",
    "fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:local": "vitest run --config vitest.config.ts",
    "test:devnet": "vitest run --config vitest.config.devnet.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "keywords": [
    "xrp",
    "xrpl",
    "trust-line",
    "mptoken",
    "flow",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "xrpl": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
