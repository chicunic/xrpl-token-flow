{
  "name": "xrpl-stablecoin-flow",
  "version": "1.0.0",
  "description": "XRPL stablecoin flow management service",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && biome check --enforce-assist=true",
    "fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "chmod +x setup-hooks.sh && ./setup-hooks.sh"
  },
  "keywords": [
    "xrp",
    "xrpl",
    "stablecoin",
    "flow",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "bip39": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
