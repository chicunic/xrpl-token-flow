{
  "name": "xrpl-stablecoin-flow",
  "version": "1.0.0",
  "description": "XRPL stablecoin flow management service",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && biome check --enforce-assist=true",
    "fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "chmod +x setup-hooks.sh && ./setup-hooks.sh"
  },
  "keywords": [
    "xrp",
    "xrpl",
    "stablecoin",
    "flow",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "bip39": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@11.0.0-dev.1005+sha512.91f84a392eea348ea4852a182912d2520273a4336f933b78cc44bc931eb999923c097e9433a9b355adc1f725725ea99082fc9f032a559df832632e764c92c798"
}
