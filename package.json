{
  "name": "xrpl-token-flow",
  "version": "1.0.0",
  "description": "XRPL token flow management service",
  "keywords": [
    "xrp",
    "xrpl",
    "trust-line",
    "mptoken",
    "flow",
    "typescript"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "check": "tsc -b --noEmit && eslint . && prettier --check .",
